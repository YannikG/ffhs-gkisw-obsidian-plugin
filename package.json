{
  "name": "ffhs-gkisw-obsidian-plugin",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "prepare": "husky",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "node scripts/write-manifest.mjs && npm run typecheck && node esbuild.config.mjs",
    "set-version": "node scripts/set-release-version.mjs",
    "deploy": "node scripts/deploy-to-vault.mjs",
    "check-markdown": "node scripts/check-markdown.mjs",
    "dev": "concurrently -c blue,magenta -n tsc,esbuild \"tsc --noEmit --watch\" \"node esbuild.config.mjs --watch\""
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/node": "^22.0.0",
    "concurrently": "^9.1.2",
    "esbuild": "^0.25.0",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "globals": "^16.2.0",
    "husky": "^9.1.7",
    "obsidian": "^1.7.2",
    "prettier": "^3.5.3",
    "sqlite-wasm-vec": "^0.1.11",
    "typescript": "~5.8.0",
    "typescript-eslint": "^8.33.0",
    "vitest": "^3.2.4"
  }
}
